# L1 Scaffolding (Not Frameworks)

kh:catch-log-primer a kh:Content ;
    rdfs:label "Catch Log Primer" ;
    kh:nodeType "content" ;
    kh:branch "kcaase" ;
    kh:url "/kcaase/catch-log-primer.html" ;
    kh:description "One-screen reference: 'A catch is a thought you noticed. That's it. You're not judging, solving, or deciding if it's silly yet.'" ;
    kh:cognitionLevel kcaase:Level1_Knowledge ;
    kh:contentType "scaffolding" .

kh:thought-type-glossary a kh:Content ;
    rdfs:label "Thought-Type Glossary" ;
    kh:nodeType "content" ;
    kh:branch "kcaase" ;
    kh:url "/kcaase/thought-types.html" ;
    kh:description "Taxonomy of 20 thought categories: reactive, aspirational, comparison, grievance, sunk-cost lament, shiny-object wish. User picks one when logging." ;
    kh:cognitionLevel kcaase:Level1_Knowledge ;
    kh:contentType "scaffolding" .

kh:observation-judgment-splitter a kh:Tool ;
    rdfs:label "Observation vs. Judgment Splitter" ;
    kh:nodeType "content" ;
    kh:branch "kcaase" ;
    kh:url "/kcaase/raw-read.html" ;
    kh:description "Micro-tool with two fields: 'What actually happened?' (raw) / 'What did you make it mean?' (read). Separates fact from emotional charge before L2." ;
    kh:cognitionLevel kcaase:Level1_Knowledge ;
    kh:contentType "scaffolding" .

kh:daily-brief-kcaase-prompt a kh:Content ;
    rdfs:label "Daily Brief KCAASE Prompt" ;
    kh:nodeType "content" ;
    kh:branch "kcaase" ;
    kh:description "Morning brief integration: 'What thought is swinging from the vines today?' Also surfaces 1-3 uncaught moments from ambient signals (calendar overruns, repeated search terms) with prompt: 'Was there a thought behind this?'" ;
    kh:cognitionLevel kcaase:Level1_Knowledge ;
    kh:contentType "workflow" ;
    kh:designNote "L1-as-service: system helps user notice what they would have let pass" .

