# Kai Hamil Unified Knowledge Graph
# Source of truth: RDF/TTL format
# Exported to: graph.json for visual rendering
# Created: April 19, 2026

@prefix kh: <https://kaihamil.com/ontology/> .
@prefix kcaase: <https://kaihamil.com/kcaase/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================
# ONTOLOGY
# ============================================

kh:Node a rdfs:Class ;
    rdfs:label "Graph Node" ;
    rdfs:comment "Any entity in the knowledge graph" .

kh:Content a rdfs:Class ;
    rdfs:label "Content" ;
    rdfs:subClassOf kh:Node ;
    rdfs:comment "Pages, posts, frameworks, tools" .

kh:Framework a rdfs:Class ;
    rdfs:label "Framework" ;
    rdfs:subClassOf kh:Content ;
    rdfs:comment "Mental models and structured thinking" .

kh:Post a rdfs:Class ;
    rdfs:label "Post" ;
    rdfs:subClassOf kh:Content ;
    rdfs:comment "Blog posts and articles" .

kh:Tool a rdfs:Class ;
    rdfs:label "Tool" ;
    rdfs:subClassOf kh:Content ;
    rdfs:comment "Interactive tools and assessments" .

kh:Collection a rdfs:Class ;
    rdfs:label "Collection" ;
    rdfs:subClassOf kh:Node ;
    rdfs:comment "Grouping containers (frameworks, wisdom, etc.)" .

kh:Paradigm a rdfs:Class ;
    rdfs:label "Paradigm" ;
    rdfs:subClassOf kh:Node ;
    rdfs:comment "Core organizing principles" .

kh:CognitionLevel a rdfs:Class ;
    rdfs:label "Cognition Level" ;
    rdfs:subClassOf kh:Node ;
    rdfs:comment "Bloom's Taxonomy / KCAASE level" .

kh:Edge a rdfs:Class ;
    rdfs:label "Edge" ;
    rdfs:comment "Relationship between nodes" .

# Properties
kh:url a rdf:Property ;
    rdfs:label "URL" ;
    rdfs:domain kh:Node ;
    rdfs:range xsd:string .

kh:description a rdf:Property ;
    rdfs:label "Description" ;
    rdfs:domain kh:Node ;
    rdfs:range xsd:string .

kh:branch a rdf:Property ;
    rdfs:label "Branch" ;
    rdfs:domain kh:Node ;
    rdfs:range xsd:string .

kh:tagline a rdf:Property ;
    rdfs:label "Tagline" ;
    rdfs:domain kh:Node ;
    rdfs:range xsd:string .

kh:nodeType a rdf:Property ;
    rdfs:label "Node Type" ;
    rdfs:domain kh:Node ;
    rdfs:range xsd:string .

kh:contains a rdf:Property ;
    rdfs:label "Contains" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:related a rdf:Property ;
    rdfs:label "Related" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:deepens a rdf:Property ;
    rdfs:label "Deepens" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:applies a rdf:Property ;
    rdfs:label "Applies" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:explores a rdf:Property ;
    rdfs:label "Explores" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:inspires a rdf:Property ;
    rdfs:label "Inspires" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:contrasts a rdf:Property ;
    rdfs:label "Contrasts" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:implements a rdf:Property ;
    rdfs:label "Implements" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

kh:opens a rdf:Property ;
    rdfs:label "Opens" ;
    rdfs:domain kh:Node ;
    rdfs:range kh:Node .

# KCAASE Properties
kh:cognitionLevel a rdf:Property ;
    rdfs:label "Cognition Level" ;
    rdfs:domain kh:Content ;
    rdfs:range kh:CognitionLevel .

kh:primaryLevel a rdf:Property ;
    rdfs:label "Primary Level" ;
    rdfs:domain kh:Content ;
    rdfs:range kh:CognitionLevel .

kh:secondaryLevel a rdf:Property ;
    rdfs:label "Secondary Level" ;
    rdfs:domain kh:Content ;
    rdfs:range kh:CognitionLevel .

kh:prerequisiteFor a rdf:Property ;
    rdfs:label "Prerequisite For" ;
    rdfs:domain kh:CognitionLevel ;
    rdfs:range kh:CognitionLevel .

kh:leadsTo a rdf:Property ;
    rdfs:label "Leads To" ;
    rdfs:domain kh:CognitionLevel ;
    rdfs:range kh:CognitionLevel .

kh:offrampAt a rdf:Property ;
    rdfs:label "Offramp At" ;
    rdfs:domain kh:CognitionLevel ;
    rdfs:range xsd:string .

kh:appPrompt a rdf:Property ;
    rdfs:label "App Prompt" ;
    rdfs:domain kh:CognitionLevel ;
    rdfs:range xsd:string .

kh:acronymLetter a rdf:Property ;
    rdfs:label "Acronym Letter" ;
    rdfs:domain kh:CognitionLevel ;
    rdfs:range xsd:string .

kh:acronymWord a rdf:Property ;
    rdfs:label "Acronym Word" ;
    rdfs:domain kh:CognitionLevel ;
    rdfs:range xsd:string .

# ============================================
# KCAASE COGNITION LEVELS
# ============================================

kcaase:Level1_Knowledge a kh:CognitionLevel ;
    rdfs:label "Knowledge" ;
    kh:acronymLetter "K" ;
    kh:acronymWord "Keep" ;
    kh:nodeType "cognition" ;
    kh:branch "kcaase" ;
    kh:description "Raw thought capture — the open gate. Not transformation, just declaration. 'I need to lose weight.'" ;
    kh:appPrompt "What did you think? State it clearly." ;
    kh:designNote "L1 is scaffolding, not teaching. Lower friction, separate observation from judgment, offer thought-type vocabulary." ;
    kh:leadsTo kcaase:Level2_Comprehension .

kcaase:Level2_Comprehension a kh:CognitionLevel ;
    rdfs:label "Comprehension" ;
    kh:acronymLetter "C" ;
    kh:acronymWord "Catching" ;
    kh:nodeType "cognition" ;
    kh:branch "kcaase" ;
    kh:description "Restate in objective terms using different descriptors. 'My weight has risen since last year.'" ;
    kh:appPrompt "What do you mean? Restate objectively." ;
    kh:prerequisiteFor kcaase:Level3_Application ;
    kh:leadsTo kcaase:Level3_Application .

kcaase:Level3_Application a kh:CognitionLevel ;
    rdfs:label "Application" ;
    kh:acronymLetter "A" ;
    kh:acronymWord "Apes" ;
    kh:nodeType "cognition" ;
    kh:branch "kcaase" ;
    kh:description "Observe how the thought manifests in reality. 'My weight has made me less active, and I exercise less.'" ;
    kh:appPrompt "When/where did this appear? How does it manifest?" ;
    kh:offrampAt "Does this actually affect you, or could it be a silly elephant?" ;
    kh:prerequisiteFor kcaase:Level4_Analysis ;
    kh:leadsTo kcaase:Level4_Analysis .

kcaase:Level4_Analysis a kh:CognitionLevel ;
    rdfs:label "Analysis" ;
    kh:acronymLetter "A" ;
    kh:acronymWord "And" ;
    kh:nodeType "cognition" ;
    kh:branch "kcaase" ;
    kh:description "Ask and answer WHY the thought is true. 'I stopped tracking my Apple Watch rings, and lost motivation to exercise, leading to a weight gain.' Leverage Root Cause Analysis and 5 Whys frameworks here." ;
    kh:appPrompt "What contributed? Why is this true? (Use 5 Whys)" ;
    kh:offrampAt "Is the 'why' related to something else entirely? Time to dismiss?" ;
    kh:prerequisiteFor kcaase:Level5_Synthesis ;
    kh:leadsTo kcaase:Level5_Synthesis .

kcaase:Level5_Synthesis a kh:CognitionLevel ;
    rdfs:label "Synthesis" ;
    kh:acronymLetter "S" ;
    kh:acronymWord "Silly" ;
    kh:nodeType "cognition" ;
    kh:branch "kcaase" ;
    kh:description "What can be done or created? 'Resume wearing my apple watch and being the person who closes the rings every day.'" ;
    kh:appPrompt "What could you do? Create options." ;
    kh:prerequisiteFor kcaase:Level6_Evaluation ;
    kh:leadsTo kcaase:Level6_Evaluation .

kcaase:Level6_Evaluation a kh:CognitionLevel ;
    rdfs:label "Evaluation" ;
    kh:acronymLetter "E" ;
    kh:acronymWord "Elephants" ;
    kh:nodeType "cognition" ;
    kh:branch "kcaase" ;
    kh:description "How will it affect the outcome? 'This will improve my burned calorie count and lose weight for the summer.'" ;
    kh:appPrompt "What's the plan? How will it affect outcomes?" .

# ============================================
# CORE STRUCTURE (from existing graph.json)
# ============================================

kh:root a kh:Node ;
    rdfs:label "Kai Hamil" ;
    kh:nodeType "root" ;
    kh:url "/" ;
    kh:description "Entry point: Quiz + System // Self" ;
    kh:opens kh:paradigm ;
    kh:contains kh:ai-quiz-v3 ;
    kh:contains kh:operations .

kh:paradigm a kh:Paradigm ;
    rdfs:label "System // Self" ;
    kh:nodeType "paradigm" ;
    kh:url "/paradigm/" ;
    kh:description "The central paradigm: Doing things better // Doing better things" ;
    kh:branch "both" ;
    kh:contains kh:system ;
    kh:contains kh:self ;
    kh:contains kh:about .

kh:system a kh:Collection ;
    rdfs:label "System" ;
    kh:nodeType "collection" ;
    kh:url "/system/" ;
    kh:tagline "Doing things better" ;
    kh:description "Science, frameworks, tools for others" ;
    kh:branch "system" ;
    kh:contrasts kh:self ;
    kh:contains kh:frameworks ;
    kh:contains kh:tools-system ;
    kh:contains kh:research .

kh:self a kh:Collection ;
    rdfs:label "Self" ;
    kh:nodeType "collection" ;
    kh:url "/self/" ;
    kh:tagline "Doing better things" ;
    kh:description "Art, wisdom, how we grow ourselves" ;
    kh:branch "self" ;
    kh:contains kh:wisdom ;
    kh:contains kh:tools-self .

kh:frameworks a kh:Collection ;
    rdfs:label "Frameworks" ;
    kh:nodeType "collection" ;
    kh:url "/frameworks/" ;
    kh:description "Mental models and structured thinking" ;
    kh:branch "system" .

kh:tools-system a kh:Collection ;
    rdfs:label "System Tools" ;
    kh:nodeType "collection" ;
    kh:url "/tools/system/" ;
    kh:description "Problem-solving and assessment tools" ;
    kh:branch "system" .

kh:research a kh:Collection ;
    rdfs:label "Research" ;
    kh:nodeType "collection" ;
    kh:url "/research/" ;
    kh:description "Explorations and drafts (disclaimer: unvalidated)" ;
    kh:branch "system" .

kh:wisdom a kh:Collection ;
    rdfs:label "Wisdom Traditions" ;
    kh:nodeType "collection" ;
    kh:url "/wisdom/" ;
    kh:description "Ancient wisdom applied to modern life" ;
    kh:branch "self" .

kh:tools-self a kh:Collection ;
    rdfs:label "Self Tools" ;
    kh:nodeType "collection" ;
    kh:url "/tools/self/" ;
    kh:description "Reflection and personal growth tools" ;
    kh:branch "self" .

kh:about a kh:Collection ;
    rdfs:label "About" ;
    kh:nodeType "collection" ;
    kh:url "/about/" ;
    kh:description "Who is behind this" ;
    kh:branch "both" .

kh:operations a kh:Collection ;
    rdfs:label "Operations" ;
    kh:nodeType "collection" ;
    kh:url "/openclaw/" ;
    kh:description "How the sausage is made" ;
    kh:branch "meta" .

