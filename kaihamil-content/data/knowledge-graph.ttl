# KCAASE Pathways
kh:solve-path a kh:Node ;
    rdfs:label "Solve It Path" ;
    kh:nodeType "pathway" ;
    kh:description "Continue through all 6 levels to create actionable solution" ;
    kh:branch "kcaase" ;
    kh:contains kcaase:Level5_Synthesis ;
    kh:contains kcaase:Level6_Evaluation ;
    kh:related kh:system-self-framework ;
    kh:related kh:post-agent-arch .

kh:dismiss-path a kh:Node ;
    rdfs:label "Silly Elephant Path" ;
    kh:nodeType "pathway" ;
    kh:description "Dismiss the thought as not worth solving" ;
    kh:branch "kcaase" ;
    kh:related kh:post-looking-inward ;
    kh:related kh:uncertainty .

