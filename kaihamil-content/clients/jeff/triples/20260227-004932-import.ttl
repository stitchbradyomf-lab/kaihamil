@prefix kh: <http://kaihamil.com/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .


# Client Profile
kh:jeff rdf:type kh:Realtor ;
    kh:name "Jeffrey Weber" ;
    kh:yearsActive "5"^^xsd:integer ;
    kh:totalTransactions "47"^^xsd:integer ;
    kh:profileUrl "https://www.homes.com/real-estate-agents/jeffrey-weber/kgce42c/" ;
    kh:activeInArea "Westfield" ;
    kh:activeInArea "Cranford" ;
    kh:activeInArea "Mountainside" ;
    kh:activeInArea "Scotch Plains" ;
    .

# Active Neighborhoods/Areas
kh:area-westfield rdf:type kh:Neighborhood ;
    kh:name "Westfield" ;
    kh:servedBy kh:jeff ;
    .
kh:area-cranford rdf:type kh:Neighborhood ;
    kh:name "Cranford" ;
    kh:servedBy kh:jeff ;
    .
kh:area-mountainside rdf:type kh:Neighborhood ;
    kh:name "Mountainside" ;
    kh:servedBy kh:jeff ;
    .
kh:area-scotch-plains rdf:type kh:Neighborhood ;
    kh:name "Scotch Plains" ;
    kh:servedBy kh:jeff ;
    .

# Transaction History
kh:tx-001 rdf:type kh:RealEstateTransaction ;
    kh:representedBy kh:jeff ;
    kh:listingKey "tx-001" ;
    kh:propertyAddress "123 Maple Street, Westfield, NJ" ;
    kh:salePrice "725000"^^xsd:decimal ;
    kh:transactionType "buyer_representation" ;
    kh:standardStatus "Closed" ;
    kh:daysOnMarket "0"^^xsd:integer ;
    kh:transactionDate "2024-01-15"^^xsd:date ;
    kh:bedrooms "4"^^xsd:integer ;
    kh:bathrooms "2.5"^^xsd:decimal ;
    kh:squareFeet "2400"^^xsd:integer ;
    kh:locatedIn "Westfield" ;
    kh:locatedIn kh:area-westfield ;
    kh:clientType "family_upgrading" ;
    .

kh:tx-002 rdf:type kh:RealEstateTransaction ;
    kh:representedBy kh:jeff ;
    kh:listingKey "tx-002" ;
    kh:propertyAddress "456 Oak Avenue, Cranford, NJ" ;
    kh:salePrice "485000"^^xsd:decimal ;
    kh:transactionType "seller_representation" ;
    kh:standardStatus "Closed" ;
