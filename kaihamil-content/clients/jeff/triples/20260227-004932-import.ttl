# Derived Patterns and Insights
kh:jeff-expertise rdf:type kh:ExpertiseProfile ;
    kh:belongsTo kh:jeff ;
    kh:specializesInPriceRange "luxury" ;
    kh:luxuryTransactions "1"^^xsd:integer ;
    kh:specializesInPriceRange "mid_market" ;
    kh:mid_marketTransactions "1"^^xsd:integer ;
    kh:handlesPropertyType "colonial" ;
    kh:handlesPropertyType "cape_cod" ;
    .